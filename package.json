{
  "name": "wellness-tracker",
  "version": "1.0.0",
  "description": "Wellness & Medication Tracker - TRT, NAD+, and daily health tracking",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build-installer": "electron-builder --win nsis"
  },
  "author": "AngelMetrix",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "node-schedule": "^2.1.1"
  },
  "build": {
    "appId": "com.angelmetrix.wellness-tracker",
    "productName": "Wellness Tracker",
    "win": {
      "target": ["portable", "nsis"],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "**/*",
      "!node_modules/.cache"
    ]
  }
}
